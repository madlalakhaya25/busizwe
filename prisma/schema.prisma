// Busizwe Burial Society - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  MEMBER
  ADMIN
  SUPER_ADMIN
}

enum PolicyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
  LAPSED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  OVERDUE
}

enum DocumentType {
  ID_DOCUMENT
  PROOF_OF_RESIDENCE
  BANK_STATEMENT
  DEATH_CERTIFICATE
  BIRTH_CERTIFICATE
  MARRIAGE_CERTIFICATE
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DependantRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  GRANDPARENT
  GRANDCHILD
  OTHER
}

enum AgeGroup {
  AGE_16_64
  AGE_65_75
  AGE_75_84
}

enum ProductCategory {
  PRINCIPAL_MEMBER_SINGLE
  IMMEDIATE_FAMILY
  SINGLE_PARENT_FAMILY
  ADULT_DEPENDANT_ADDON
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  profile   Profile?
  policies  Policy[]
  documents Document[]
  payments  Payment[]

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  phone       String?
  dateOfBirth DateTime?
  idNumber    String?   @unique
  address     String?
  city        String?
  province    String?
  postalCode  String?
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ProductCategory
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  pricingTiers PricingTier[]
  policies     Policy[]

  @@index([category])
  @@map("products")
}

model PricingTier {
  id          String    @id @default(cuid())
  productId   String
  ageGroup    AgeGroup
  coverAmount Decimal   @db.Decimal(10, 2)
  premium     Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  policies    Policy[]

  @@unique([productId, ageGroup, coverAmount])
  @@index([productId])
  @@map("pricing_tiers")
}

model Policy {
  id             String       @id @default(cuid())
  userId         String
  productId      String
  pricingTierId  String
  policyNumber   String       @unique
  status         PolicyStatus @default(PENDING)
  startDate      DateTime?
  endDate        DateTime?
  monthlyPremium Decimal      @db.Decimal(10, 2)
  coverAmount    Decimal      @db.Decimal(10, 2)
  notes          String?
  approvedAt     DateTime?
  approvedBy     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
  pricingTier PricingTier @relation(fields: [pricingTierId], references: [id])
  dependants  Dependant[]
  payments    Payment[]

  @@index([userId])
  @@index([status])
  @@index([policyNumber])
  @@map("policies")
}

model Dependant {
  id           String                @id @default(cuid())
  policyId     String
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  idNumber     String?
  relationship DependantRelationship
  phone        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?

  policy       Policy                @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@map("dependants")
}

model Document {
  id         String         @id @default(cuid())
  userId     String
  type       DocumentType
  status     DocumentStatus @default(PENDING)
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  notes      String?
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("documents")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  policyId      String
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  reference     String?       @unique
  paymentMethod String?
  notes         String?
  recordedBy    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([policyId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}
